# Dev env — isolated from prod. Source of truth for bpt-dev-*.service units.
#
# Service configs — all testnet/demo (never live credentials in dev)
BPT_REFDATA_CONFIG=config/muninn.qa-okx.toml
BPT_MD_GATEWAY_CONFIG=config/huginn.qa-okx.toml
BPT_ORDER_GATEWAY_CONFIG=config/heimdall.qa-okx.toml
BPT_STRATEGY_CONFIG=config/avellaneda_stoikov.qa-okx.toml
BPT_ANALYTICS_CONFIG=config/tyr.qa-okx.toml

# Dashboard bridge args
BPT_BRIDGE_CONFIG=dashboard/bridge/config/bridge.live.toml
BPT_BRIDGE_MODE=paper
BPT_BRIDGE_STRATEGY=AvellanedaStoikovStrategy
BPT_BRIDGE_SYMBOL=BTC-USDT
BPT_BRIDGE_EXCHANGE=OKX
BPT_BRIDGE_INST_TYPE=SPOT

# Dev fallback for ygg::secrets::fetch when running without systemd-creds.
# Files here are plaintext KEY=value. Not committed to git.
BPT_DEV_CREDS=/home/jseow/.bpt-secrets
