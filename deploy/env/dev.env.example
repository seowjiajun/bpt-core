# Dev env — isolated from prod. Source of truth for bpt-dev-*.service units.
#
# Service configs are interpreted relative to each service's WorkingDirectory
# (i.e. $BPT_ROOT/<svc>/), so the paths below are deliberately not absolute.
# Switch a service to a different venue by pointing its CONFIG var at the
# matching `.qa-<venue>.toml` file under that service's config/ directory.

# Trading-side (OKX testnet by default)
BPT_REFDATA_CONFIG=config/bpt-refdata.qa-okx.toml
BPT_MD_GATEWAY_CONFIG=config/bpt-md-gateway.qa-okx.toml
BPT_ORDER_GATEWAY_CONFIG=config/bpt-order-gateway.qa-okx.toml
BPT_STRATEGY_CONFIG=config/avellaneda_stoikov.qa-okx.toml
BPT_ANALYTICS_CONFIG=config/bpt-analytics.qa-okx.toml

# Options-radar path (Deribit testnet). The radar stack joins VolSurface from
# the pricer with InstrumentStats from md-gateway, so both have to point at
# the same venue. To swap into the radar stack, override BPT_REFDATA_CONFIG +
# BPT_MD_GATEWAY_CONFIG to the Deribit configs:
#   BPT_REFDATA_CONFIG=config/bpt-refdata.qa-deribit.toml
#   BPT_MD_GATEWAY_CONFIG=config/bpt-md-gateway.qa-deribit.toml
BPT_PRICER_CONFIG=config/bpt-pricer.qa-deribit.toml
BPT_RADAR_CONFIG=config/bpt-radar.qa-deribit.toml

# Dashboard bridge args
BPT_BRIDGE_CONFIG=config/bridge.live.toml
BPT_BRIDGE_PROFILE=deploy/config/profile/qa-okx.toml
BPT_BRIDGE_MODE=paper
BPT_BRIDGE_STRATEGY=AvellanedaStoikovStrategy
BPT_BRIDGE_SYMBOL=BTC-USDT
BPT_BRIDGE_EXCHANGE=OKX
BPT_BRIDGE_INST_TYPE=SPOT

# Dev fallback for ygg::secrets::fetch when running without systemd-creds.
# Files here are plaintext KEY=value. Not committed to git.
BPT_DEV_CREDS=${HOME}/.bpt-secrets
