# Hyperliquid testnet — funding arb plumbing test.
#
# Identical to dev-hyperliquid.env apart from:
#   - BPT_STRATEGY_CONFIG points at the funding_arb.qa-hyperliquid wrapper
#   - bridge env vars cleared (bridge runs AvellanedaStoikov-specific code
#     that wouldn't have anything sensible to show for a paired spot+perp
#     strategy; reattach when funding arb gets first-class bridge support)
#
# Copy into a local .env (the .env files are gitignored):
#   cp deploy/env/dev-hyperliquid-funding-arb.env.example \
#      deploy/env/dev-hyperliquid-funding-arb.env
# Activate:    ./deploy/switch-env.sh dev-hyperliquid-funding-arb
# Restart:     systemctl --user daemon-reload && systemctl --user restart bpt-trading.target
# Watch logs:  journalctl --user -fu bpt-strategy
BPT_REFDATA_CONFIG=config/muninn.qa-hyperliquid.toml
BPT_MD_GATEWAY_CONFIG=config/huginn.qa-hyperliquid.toml
BPT_ORDER_GATEWAY_CONFIG=config/heimdall.qa-hyperliquid.toml
BPT_STRATEGY_CONFIG=config/funding_arb.qa-hyperliquid.toml
BPT_ANALYTICS_CONFIG=config/bpt-analytics.qa-hyperliquid.toml
BPT_BOOK_CONFIG=config/book.qa-hyperliquid.toml
BPT_BRIDGE_CONFIG=
BPT_BRIDGE_MODE=
BPT_BRIDGE_STRATEGY=
BPT_BRIDGE_SYMBOL=
BPT_BRIDGE_EXCHANGE=
BPT_BRIDGE_INST_TYPE=
BPT_ENV=dev
