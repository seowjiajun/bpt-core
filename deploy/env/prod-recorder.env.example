# Active env for a recording-only host. Drop this in as
# $BPT_DEPLOY_ROOT/config/active/env on the VM.
#
# What runs on this host:
#   - bpt-tape.service            (the entire recording stack — single
#                                  binary; no Aeron, no MediaDriver, no
#                                  refdata. Loads instrument_mapping.json
#                                  directly for universe; venue WS frames
#                                  go straight to disk via Tape.)
#   - bpt-recording-rotate.timer  (00:30 UTC daily wslog → Parquet)
#   - bpt-recording-heartbeat.timer (5-min freshness check → Healthchecks.io)
#
# What does NOT run:
#   - bpt-transport (no Aeron consumers on this host)
#   - refdata, order-gateway, strategy, analytics, book, bridge
#   bpt-recording.target deliberately excludes everything trading-related.

BPT_ENV=prod

# Path to the recording config — points at the venue(s) you want this
# host to capture. Use the matching bpt-tape.<venue>.toml in the active
# config dir; the deploy seeds these on first install.
BPT_TAPE_CONFIG=config/bpt-tape.hl.toml

# Output / cache locations. Default for both is /opt/bpt/data/...; only
# override if you've mounted a separate disk for capture.
# BPT_RAW_ROOT=/opt/bpt/data/raw
# BPT_PARQUET_ROOT=/opt/bpt/data/backtest-cache

# Trading-stack vars left blank — they're consumed by other units that
# this host doesn't run, but the env file is shared so we set empty
# placeholders to avoid systemd substitution warnings.
BPT_REFDATA_CONFIG=
BPT_MD_GATEWAY_CONFIG=
BPT_ORDER_GATEWAY_CONFIG=
BPT_STRATEGY_CONFIG=
BPT_ANALYTICS_CONFIG=
BPT_BOOK_CONFIG=
BPT_BRIDGE_CONFIG=
