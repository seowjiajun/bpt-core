# Active env for a recording-only host. Drop this in as
# $BPT_DEPLOY_ROOT/config/active/env on the VM.
#
# What runs on this host:
#   - bpt-transport.service       (Aeron media driver — recorder uses
#                                  the in-process publisher path, no
#                                  external IPC, but bpt-transport is
#                                  cheap and already part of the stack
#                                  layout so we keep it for symmetry)
#   - bpt-md-recorder.service     (bpt-md-gateway running with
#                                  [recording] enabled in its config)
#   - bpt-recording-rotate.timer  (00:30 UTC daily wslog → Parquet)
#
# What does NOT run:
#   - refdata, order-gateway, strategy, analytics, book, bridge.
#     bpt-recording.target deliberately excludes them.

BPT_ENV=prod

# Path to the recording config — points at the venue you want this host
# to capture. Use the matching bpt-md-gateway.recording-<venue>.toml
# in the active config dir; the deploy seeds these on first install.
BPT_MD_RECORDER_CONFIG=config/bpt-md-gateway.recording-hl.toml

# Output / cache locations. Default for both is /opt/bpt/data/...; only
# override if you've mounted a separate disk for capture.
# BPT_RAW_ROOT=/opt/bpt/data/raw
# BPT_PARQUET_ROOT=/opt/bpt/data/backtest-cache

# Trading-stack vars left blank — they're consumed by other units that
# this host doesn't run, but the env file is shared so we set empty
# placeholders to avoid systemd substitution warnings.
BPT_REFDATA_CONFIG=
BPT_MD_GATEWAY_CONFIG=
BPT_ORDER_GATEWAY_CONFIG=
BPT_STRATEGY_CONFIG=
BPT_ANALYTICS_CONFIG=
BPT_BOOK_CONFIG=
BPT_BRIDGE_CONFIG=
