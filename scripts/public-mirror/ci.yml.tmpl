name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

# Cancel in-progress runs on the same branch when a new push arrives —
# the latest commit's result is what matters; older builds are wasted CI minutes.
concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ── Bazel: builds + tests every C++ service ──────────────────────────────
  # Cold build is ~5 min (network-bound on the Aeron http_archive fetch),
  # cached runs settle around 1 min. Bazel disk cache + repository cache
  # are keyed on MODULE.bazel + .bazelversion so toolchain bumps invalidate
  # them cleanly.
  bazel:
    name: bazel build + test
    runs-on: ubuntu-24.04
    timeout-minutes: 25
    steps:
      - uses: actions/checkout@v4

      - name: Install build deps
        run: |
          sudo apt-get update
          sudo apt-get install -y build-essential libssl-dev pkg-config

      - name: Set up Bazel
        uses: bazel-contrib/setup-bazel@0.15.0
        with:
          bazelisk-cache: true
          disk-cache: ${{ github.workflow }}
          repository-cache: true

      - name: bazel build //...
        run: bazel build //...

      - name: bazel test //...
        run: bazel test //... --test_output=errors

  # ── Java: builds the Aeron MediaDriver shadow JAR ────────────────────────
  java:
    name: java shadow jar
    runs-on: ubuntu-24.04
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'
          cache: gradle

      - name: ./gradlew shadowJar
        working-directory: transport/aeron
        run: ./gradlew shadowJar --no-daemon

  # ── Frontend: tsc + vite build ───────────────────────────────────────────
  frontend:
    name: dashboard frontend
    runs-on: ubuntu-24.04
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4

      - name: Set up Node 20
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: npm
          cache-dependency-path: dashboard/frontend/package-lock.json

      - name: npm ci
        working-directory: dashboard/frontend
        run: npm ci

      - name: npm run build
        working-directory: dashboard/frontend
        run: npm run build

  # ── Formatting: clang-format, ruff, prettier ─────────────────────────────
  format:
    name: format check
    runs-on: ubuntu-24.04
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@v4

      - name: Install formatters
        run: |
          sudo apt-get update
          # clang-format-19 ships pre-built on ubuntu-24.04. Local dev is
          # on v22; the .clang-format settings (Google base + 4-space
          # indent) are stable across these versions.
          sudo apt-get install -y clang-format-19 python3-pip
          sudo ln -sf /usr/bin/clang-format-19 /usr/local/bin/clang-format
          pip install --user ruff==0.15.5

      - name: clang-format --dry-run on tracked C++
        run: |
          mapfile -t FILES < <(git ls-files '*.cpp' '*.h' '*.hpp' '*.cc' \
            | grep -v 'messages/generated/' \
            | grep -v 'transport/aeron/build/' \
            | grep -v 'vcpkg/' )
          clang-format --dry-run --Werror "${FILES[@]}"

      - name: ruff format --check
        run: |
          export PATH="$HOME/.local/bin:$PATH"
          for d in bpt-universe bpt-ops scripts; do
            [ -d "$d" ] && ruff format --check "$d"
          done

      - name: prettier --check (dashboard)
        working-directory: dashboard/frontend
        run: |
          npm ci
          npm run format:check
