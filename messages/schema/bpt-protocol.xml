<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="bpt.messages"
                   id="1"
                   version="14"
                   semanticVersion="1.14.0"
                   description="BPT trading stack — reconstructed from generated C++"
                   byteOrder="littleEndian">

  <types>
    <composite name="messageHeader">
      <type name="blockLength" primitiveType="uint16"/>
      <type name="templateId"  primitiveType="uint16"/>
      <type name="schemaId"    primitiveType="uint16"/>
      <type name="version"     primitiveType="uint16"/>
    </composite>
    <composite name="groupSizeEncoding">
      <type name="blockLength" primitiveType="uint16"/>
      <type name="numInGroup"  primitiveType="uint16"/>
    </composite>

    <type name="Char8" primitiveType="char" length="8" characterEncoding="ASCII"/>
    <type name="Char24" primitiveType="char" length="24" characterEncoding="ASCII"/>
    <type name="Char32" primitiveType="char" length="32" characterEncoding="ASCII"/>

    <enum name="AckStatus" encodingType="uint8">
      <validValue name="OK">0</validValue>
      <validValue name="REJECTED">1</validValue>
      <validValue name="NOT_FOUND">2</validValue>
    </enum>
    <enum name="BacktestCommand" encodingType="uint8">
      <validValue name="START">0</validValue>
      <validValue name="STOP">1</validValue>
      <validValue name="RESET">2</validValue>
    </enum>
    <enum name="DeltaUpdateType" encodingType="uint8">
      <validValue name="ADD">0</validValue>
      <validValue name="MODIFY">1</validValue>
      <validValue name="REMOVE">2</validValue>
    </enum>
    <enum name="ExchangeId" encodingType="uint8">
      <validValue name="ALL">0</validValue>
      <validValue name="BINANCE">1</validValue>
      <validValue name="OKX">2</validValue>
      <validValue name="HYPERLIQUID">3</validValue>
      <validValue name="DERIBIT">4</validValue>
    </enum>
    <enum name="ExecStatus" encodingType="uint8">
      <validValue name="ACKED">0</validValue>
      <validValue name="FILLED">1</validValue>
      <validValue name="PARTIAL">2</validValue>
      <validValue name="REJECTED">3</validValue>
      <validValue name="CANCELLED">4</validValue>
    </enum>
    <enum name="FeeCurrency" encodingType="uint8">
      <validValue name="USDT">0</validValue>
      <validValue name="BTC">1</validValue>
      <validValue name="ETH">2</validValue>
      <validValue name="BNB">3</validValue>
      <validValue name="USD">4</validValue>
    </enum>
    <enum name="InstrumentStatus" encodingType="uint8">
      <validValue name="ACTIVE">0</validValue>
      <validValue name="INACTIVE">1</validValue>
      <validValue name="HALTED">2</validValue>
      <validValue name="PRE_DELIVERY">3</validValue>
    </enum>
    <enum name="InstrumentType" encodingType="uint8">
      <validValue name="SPOT">0</validValue>
      <validValue name="FUTURE">1</validValue>
      <validValue name="PERPETUAL">2</validValue>
      <validValue name="OPTION">3</validValue>
    </enum>
    <enum name="OptionSide" encodingType="uint8">
      <validValue name="CALL">0</validValue>
      <validValue name="PUT">1</validValue>
      <validValue name="NA">2</validValue>
    </enum>
    <enum name="OrderSide" encodingType="uint8">
      <validValue name="BUY">0</validValue>
      <validValue name="SELL">1</validValue>
    </enum>
    <enum name="OrderType" encodingType="uint8">
      <validValue name="MARKET">0</validValue>
      <validValue name="LIMIT">1</validValue>
      <validValue name="POST_ONLY">2</validValue>
    </enum>
    <enum name="RefDataErrorType" encodingType="uint8">
      <validValue name="EXCHANGE_NOT_CONFIGURED">1</validValue>
      <validValue name="SNAPSHOT_FAILED">2</validValue>
      <validValue name="DELTA_FEED_LOST">3</validValue>
      <validValue name="LOOKUP_FAILED">4</validValue>
    </enum>
    <enum name="RejectReason" encodingType="uint8">
      <validValue name="OK">0</validValue>
      <validValue name="INVALID_PRICE">1</validValue>
      <validValue name="INVALID_QTY">2</validValue>
      <validValue name="INSUFFICIENT_BALANCE">3</validValue>
      <validValue name="RATE_LIMITED">4</validValue>
      <validValue name="EXCHANGE_ERROR">5</validValue>
      <validValue name="RISK_REJECTED">6</validValue>
      <validValue name="DUPLICATE_ORDER_ID">7</validValue>
    </enum>
    <enum name="RejectSource" encodingType="uint8">
      <validValue name="EXCHANGE">0</validValue>
      <validValue name="GATEWAY">1</validValue>
      <validValue name="RISK">2</validValue>
    </enum>
    <enum name="TimeInForce" encodingType="uint8">
      <validValue name="GTC">0</validValue>
      <validValue name="IOC">1</validValue>
      <validValue name="FOK">2</validValue>
    </enum>
    <enum name="TradeSide" encodingType="uint8">
      <validValue name="BUY">0</validValue>
      <validValue name="SELL">1</validValue>
    </enum>
  </types>

  <sbe:message name="RefDataSubscriptionRequest" id="1">
    <field name="correlationId" id="1" type="uint64"/>
    <field name="timestampNs" id="2" type="uint64"/>
    <group name="instruments" id="3" dimensionType="groupSizeEncoding">
      <field name="symbol" id="1" type="Char24"/>
      <field name="exchange" id="2" type="Char8"/>
    </group>
    <group name="canonicalFilter" id="4" dimensionType="groupSizeEncoding">
      <field name="baseCurrency" id="1" type="Char8"/>
      <field name="quoteCurrency" id="2" type="Char8"/>
      <field name="instrumentType" id="3" type="InstrumentType"/>
      <field name="exchange" id="4" type="Char8"/>
    </group>
  </sbe:message>

  <sbe:message name="RefDataSnapshot" id="2">
    <field name="correlationId" id="1" type="uint64"/>
    <field name="snapshotSeqNum" id="2" type="uint64"/>
    <field name="timestampNs" id="3" type="uint64"/>
    <group name="instruments" id="4" dimensionType="groupSizeEncoding">
      <field name="instrumentId" id="1" type="uint64"/>
      <field name="symbol" id="2" type="Char24"/>
      <field name="exchange" id="3" type="Char8"/>
      <field name="baseCurrency" id="4" type="Char8"/>
      <field name="quoteCurrency" id="5" type="Char8"/>
      <field name="instrumentType" id="6" type="InstrumentType"/>
      <field name="status" id="7" type="InstrumentStatus"/>
      <field name="lotSize" id="8" type="double"/>
      <field name="tickSize" id="9" type="double"/>
      <field name="contractSize" id="10" type="double"/>
      <field name="expiryDate" id="11" type="uint32"/>
      <field name="underlying" id="12" type="Char24"/>
      <field name="optionSide" id="13" type="OptionSide"/>
      <field name="strikePrice" id="14" type="double"/>
    </group>
  </sbe:message>

  <sbe:message name="RefDataDelta" id="3">
    <field name="deltaSeqNum" id="1" type="uint64"/>
    <field name="timestampNs" id="2" type="uint64"/>
    <field name="updateType" id="3" type="DeltaUpdateType"/>
    <field name="instrumentId" id="4" type="uint64"/>
    <field name="symbol" id="5" type="Char24"/>
    <field name="exchange" id="6" type="Char8"/>
    <field name="baseCurrency" id="7" type="Char8"/>
    <field name="quoteCurrency" id="8" type="Char8"/>
    <field name="instrumentType" id="9" type="InstrumentType"/>
    <field name="status" id="10" type="InstrumentStatus"/>
    <field name="lotSize" id="11" type="double"/>
    <field name="tickSize" id="12" type="double"/>
    <field name="contractSize" id="13" type="double"/>
    <field name="expiryDate" id="14" type="uint32"/>
    <field name="underlying" id="15" type="Char24"/>
    <field name="optionSide" id="16" type="OptionSide"/>
    <field name="strikePrice" id="17" type="double"/>
  </sbe:message>

  <sbe:message name="MdSubscribeBatch" id="4">
    <field name="correlationId" id="1" type="uint64"/>
    <field name="timestampNs" id="2" type="uint64"/>
    <group name="instruments" id="3" dimensionType="groupSizeEncoding">
      <field name="instrumentId" id="1" type="uint64"/>
      <field name="exchange" id="2" type="Char8"/>
      <field name="symbol" id="3" type="Char24"/>
      <field name="depth" id="4" type="uint8"/>
    </group>
  </sbe:message>

  <sbe:message name="MdSubscriptionAck" id="5">
    <field name="correlationId" id="1" type="uint64"/>
    <field name="timestampNs" id="2" type="uint64"/>
    <field name="instrumentId" id="3" type="uint64"/>
    <field name="exchange" id="4" type="Char8"/>
    <field name="ackStatus" id="5" type="AckStatus"/>
  </sbe:message>

  <sbe:message name="MdSubscriptionHeartbeat" id="6">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="instrumentId" id="2" type="uint64"/>
    <field name="seqNum" id="3" type="uint64"/>
  </sbe:message>

  <sbe:message name="MdMarketData" id="7">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="instrumentId" id="2" type="uint64"/>
    <field name="bidPrice" id="3" type="double"/>
    <field name="bidQty" id="4" type="double"/>
    <field name="askPrice" id="5" type="double"/>
    <field name="askQty" id="6" type="double"/>
    <field name="seqNum" id="7" type="uint64"/>
  </sbe:message>

  <sbe:message name="MdTrade" id="8">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="instrumentId" id="2" type="uint64"/>
    <field name="price" id="3" type="double"/>
    <field name="qty" id="4" type="double"/>
    <field name="side" id="5" type="TradeSide"/>
    <field name="seqNum" id="6" type="uint64"/>
  </sbe:message>

  <sbe:message name="MdServiceHeartbeat" id="9">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="seqNum" id="2" type="uint64"/>
  </sbe:message>

  <sbe:message name="NewOrder" id="10">
    <field name="orderId" id="1" type="uint64"/>
    <field name="exchangeId" id="2" type="ExchangeId"/>
    <field name="instrumentId" id="3" type="uint64"/>
    <field name="side" id="4" type="OrderSide"/>
    <field name="orderType" id="5" type="OrderType"/>
    <field name="timeInForce" id="6" type="TimeInForce"/>
    <field name="price" id="7" type="int64"/>
    <field name="quantity" id="8" type="uint64"/>
    <field name="timestampNs" id="9" type="uint64"/>
    <field name="exchangeSymbol" id="10" type="Char32"/>
  </sbe:message>

  <sbe:message name="CancelOrder" id="11">
    <field name="orderId" id="1" type="uint64"/>
    <field name="exchangeId" id="2" type="ExchangeId"/>
    <field name="instrumentId" id="3" type="uint64"/>
    <field name="timestampNs" id="4" type="uint64"/>
  </sbe:message>

  <sbe:message name="CancelAll" id="12">
    <field name="exchangeId" id="1" type="ExchangeId"/>
    <field name="instrumentId" id="2" type="uint64"/>
    <field name="timestampNs" id="3" type="uint64"/>
  </sbe:message>

  <sbe:message name="ModifyOrder" id="13">
    <field name="orderId" id="1" type="uint64"/>
    <field name="exchangeId" id="2" type="ExchangeId"/>
    <field name="instrumentId" id="3" type="uint64"/>
    <field name="newPrice" id="4" type="int64"/>
    <field name="newQuantity" id="5" type="uint64"/>
    <field name="timestampNs" id="6" type="uint64"/>
  </sbe:message>

  <sbe:message name="ExecutionReport" id="14">
    <field name="orderId" id="1" type="uint64"/>
    <field name="exchangeOrderId" id="2" type="uint64"/>
    <field name="exchangeId" id="3" type="ExchangeId"/>
    <field name="instrumentId" id="4" type="uint64"/>
    <field name="status" id="5" type="ExecStatus"/>
    <field name="side" id="6" type="OrderSide"/>
    <field name="orderType" id="7" type="OrderType"/>
    <field name="price" id="8" type="int64"/>
    <field name="filledQty" id="9" type="uint64"/>
    <field name="remainingQty" id="10" type="uint64"/>
    <field name="rejectReason" id="11" type="RejectReason"/>
    <field name="fee" id="12" type="int64"/>
    <field name="feeCurrency" id="13" type="FeeCurrency"/>
    <field name="timestampNs" id="14" type="uint64"/>
    <field name="localTsNs" id="15" type="uint64"/>
    <field name="rejectSource" id="16" type="RejectSource"/>
  </sbe:message>

  <sbe:message name="OrderGatewayHeartbeat" id="15">
    <field name="serviceId" id="1" type="uint8"/>
    <field name="timestampNs" id="2" type="uint64"/>
    <field name="ordersInFlight" id="3" type="uint16"/>
    <field name="exchangeStatus" id="4" type="uint8"/>
  </sbe:message>

  <sbe:message name="RefDataReady" id="16">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="exchangesLoaded" id="2" type="uint8"/>
    <field name="instrumentCount" id="3" type="uint16"/>
    <field name="feeSchedulesLoaded" id="4" type="uint8"/>
    <field name="fundingRatesLoaded" id="5" type="uint8"/>
  </sbe:message>

  <sbe:message name="RefDataError" id="17">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="errorType" id="2" type="RefDataErrorType"/>
    <field name="exchangeId" id="3" type="ExchangeId"/>
    <field name="instrumentId" id="4" type="uint64"/>
  </sbe:message>

  <sbe:message name="FundingRate" id="18">
    <field name="exchangeId" id="1" type="ExchangeId"/>
    <field name="instrumentId" id="2" type="uint64"/>
    <field name="rateBps" id="3" type="int32"/>
    <field name="nextFundingTs" id="4" type="uint64"/>
    <field name="collectedTs" id="5" type="uint64"/>
  </sbe:message>

  <sbe:message name="FeeSchedule" id="19">
    <field name="exchangeId" id="1" type="ExchangeId"/>
    <field name="instrumentId" id="2" type="uint64"/>
    <field name="instrumentType" id="3" type="InstrumentType"/>
    <field name="makerFeeBps" id="4" type="int16"/>
    <field name="takerFeeBps" id="5" type="int16"/>
    <field name="updatedTs" id="6" type="uint64"/>
  </sbe:message>

  <sbe:message name="MdOrderBook" id="20">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="instrumentId" id="2" type="uint64"/>
    <field name="seqNum" id="3" type="uint64"/>
    <group name="bids" id="4" dimensionType="groupSizeEncoding">
      <field name="price" id="1" type="double"/>
      <field name="qty" id="2" type="double"/>
    </group>
    <group name="asks" id="5" dimensionType="groupSizeEncoding">
      <field name="price" id="1" type="double"/>
      <field name="qty" id="2" type="double"/>
    </group>
  </sbe:message>

  <sbe:message name="VolSurface" id="21">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="exchangeId" id="2" type="ExchangeId"/>
    <field name="underlying" id="3" type="Char24"/>
    <field name="seqNum" id="4" type="uint64"/>
    <group name="points" id="5" dimensionType="groupSizeEncoding">
      <field name="instrumentId" id="1" type="uint64"/>
      <field name="expiryDate" id="2" type="uint32"/>
      <field name="strikePrice" id="3" type="double"/>
      <field name="optionSide" id="4" type="OptionSide"/>
      <field name="impliedVol" id="5" type="double"/>
      <field name="forwardPrice" id="6" type="double"/>
      <field name="timeToExpiry" id="7" type="double"/>
      <field name="bidIv" id="8" type="double"/>
      <field name="askIv" id="9" type="double"/>
      <field name="bidPrice" id="10" type="double"/>
      <field name="askPrice" id="11" type="double"/>
      <field name="delta" id="12" type="double"/>
      <field name="gamma" id="13" type="double"/>
      <field name="vega" id="14" type="double"/>
      <field name="theta" id="15" type="double"/>
    </group>
  </sbe:message>

  <sbe:message name="PricerHeartbeat" id="22">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="seqNum" id="2" type="uint64"/>
  </sbe:message>

  <sbe:message name="PricerReady" id="23">
    <field name="timestampNs" id="1" type="uint64"/>
    <field name="exchangesLoaded" id="2" type="uint8"/>
    <field name="underlyingCount" id="3" type="uint16"/>
    <field name="pointCount" id="4" type="uint32"/>
  </sbe:message>

  <sbe:message name="BacktestAck" id="24">
    <field name="tickSeqNum" id="1" type="uint64"/>
    <field name="simulationTs" id="2" type="uint64"/>
  </sbe:message>

  <sbe:message name="BacktestControl" id="25">
    <field name="command" id="1" type="BacktestCommand"/>
    <field name="tickSeqNum" id="2" type="uint64"/>
    <field name="simulationTs" id="3" type="uint64"/>
  </sbe:message>

  <sbe:message name="AccountSnapshotRequest" id="26">
    <field name="exchangeId" id="1" type="ExchangeId"/>
    <field name="correlationId" id="2" type="uint64"/>
    <field name="timestampNs" id="3" type="uint64"/>
  </sbe:message>

  <sbe:message name="AccountSnapshot" id="27">
    <field name="exchangeId" id="1" type="ExchangeId"/>
    <field name="correlationId" id="2" type="uint64"/>
    <field name="timestampNs" id="3" type="uint64"/>
    <field name="availableBalanceE8" id="4" type="int64"/>
    <field name="totalEquityE8" id="5" type="int64"/>
    <group name="positions" id="6" dimensionType="groupSizeEncoding">
      <field name="exchangeSymbol" id="1" type="Char32"/>
      <field name="netQtyE8" id="2" type="int64"/>
      <field name="avgEntryPriceE8" id="3" type="int64"/>
      <field name="unrealizedPnlE8" id="4" type="int64"/>
    </group>
    <!-- Per-currency cash balances. OKX reports per-ccy equity + availBal in
         the /account/balance `details[]` array; we want the dashboard to show
         a separate cash row per currency instead of collapsing everything to
         a single USDC-labeled line. -->
    <group name="currencyBalances" id="7" dimensionType="groupSizeEncoding">
      <field name="ccy" id="1" type="Char8"/>
      <field name="equityE8" id="2" type="int64"/>
      <field name="availableBalanceE8" id="3" type="int64"/>
    </group>
  </sbe:message>

  <!-- Consolidated multi-venue balance snapshot produced by bpt-book.
       Flat list of (venue, sub_account, currency) → balance rows. Each
       row is atomic; consumers derive per-venue, per-sub-account, or
       cross-venue aggregates by summing on demand.

       sub_account is a free-form short label mapping to the venue's
       native concept: "perps"/"spot" on HL, "trading"/"funding" on OKX,
       "spot"/"futures" on Binance, "main" on Deribit.

       Named BalanceSnapshot (not BookSnapshot) to avoid confusion with
       MdOrderBook — "book" as a standalone word is already taken by
       order-book data. Future companion messages under the bpt-book
       service will follow the same pattern: PositionSnapshot, etc. -->
  <sbe:message name="BalanceSnapshot" id="28">
    <field name="correlationId" id="1" type="uint64"/>
    <field name="timestampNs" id="2" type="uint64"/>
    <group name="balances" id="3" dimensionType="groupSizeEncoding">
      <field name="exchangeId" id="1" type="ExchangeId"/>
      <field name="subAccount" id="2" type="Char8"/>
      <field name="ccy" id="3" type="Char8"/>
      <field name="totalE8" id="4" type="int64"/>
      <field name="freeE8" id="5" type="int64"/>
      <field name="holdE8" id="6" type="int64"/>
    </group>
  </sbe:message>

</sbe:messageSchema>
