# Build output
build/
build-cmake/

# Bazel convenience symlinks (output dirs, not sources)
bazel-*

# Per-service bin/ output dirs (populated by deploy scripts that copy
# binaries out of bazel-bin/ for systemd unit ExecStart paths). Build
# artefact, not source.
bpt-*/bin/
dashboard/bridge/bin/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# Runtime artifacts
*.pid
.*.pid
logs/
*.log

# vcpkg (bootstrapped at build time, not checked in)
vcpkg/

# Secrets / local env
.env
*.env
.bpt-secrets/

# Editor
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# Dashboard frontend
dashboard/frontend/node_modules/
dashboard/frontend/dist/

# Backtest results (per-run output)
bpt-backtester/results/

# OS
.DS_Store
Thumbs.db

# Python (data-forge)
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
dist/
*.egg-info/

# Java (bpt-transport)
transport/aeron/.gradle/
transport/aeron/build/
messages/generated/

# Terraform (infra/)
# State backend lives in S3 + DynamoDB lock table; never commit local state.
infra/terraform/**/.terraform/
infra/terraform/**/.terraform.lock.hcl
infra/terraform/**/terraform.tfstate
infra/terraform/**/terraform.tfstate.backup
infra/terraform/**/*.tfvars
infra/terraform/**/*.tfvars.json
# Plan output files (may contain credential outputs)
infra/terraform/**/*.tfplan

# MkDocs build output
site/_build/
